{
  "info": {
    "name": "Student Activity Portal",
    "description": "API collection cho Student Activity Portal backend. Base URL: http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TenNguoiDung\": \"Nguyen Van A\",\n  \"Email\": \"nguyenvana@example.com\",\n  \"MatKhau\": \"password123\",\n  \"MaSV\": \"SV001\",\n  \"SDT\": \"0912345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data) {",
                  "  if (res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  }",
                  "  if (res.data.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email\": \"nguyenvana@example.com\",\n  \"MatKhau\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login. Token tu dong luu vao bien collection."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh-token"]
            }
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email\": \"nguyenvana@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"MatKhauMoi\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            }
          },
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"MatKhauCu\": \"password123\",\n  \"MatKhauMoi\": \"newpassword456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Thong Bao (Notification)",
      "item": [
        {
          "name": "Send Notification (ADMIN/CHU_CLB)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.MaThongBao) {",
                  "  pm.collectionVariables.set('notificationId', res.data.MaThongBao);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TieuDe\": \"Thong bao moi\",\n  \"NoiDung\": \"Noi dung thong bao\",\n  \"MaNguoiDung\": \"<target-user-id>\",\n  \"LoaiThongBao\": \"HE_THONG\",\n  \"KenhGui\": [\"IN_APP\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/send",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "send"]
            },
            "description": "Gui thong bao cho 1 nguoi dung. KenhGui: IN_APP, EMAIL, SMS. Yeu cau role ADMIN hoac CHU_CLB."
          },
          "response": []
        },
        {
          "name": "Send Bulk Notification (ADMIN/CHU_CLB)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"TieuDe\": \"Thong bao toan truong\",\n  \"NoiDung\": \"Noi dung gui cho tat ca\",\n  \"LoaiThongBao\": \"HE_THONG\",\n  \"KenhGui\": [\"IN_APP\", \"EMAIL\"],\n  \"TatCa\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/send-bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "send-bulk"]
            },
            "description": "Gui thong bao hang loat. Target: TatCa=true (all users), MaToChuc (club members), DanhSachNguoiDung (list IDs). ThoiGianGui for scheduled."
          },
          "response": []
        },
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "LoaiThongBao", "value": "HE_THONG", "disabled": true },
                { "key": "TrangThai", "value": "CHUA_DOC", "disabled": true }
              ]
            },
            "description": "Lay danh sach thong bao cua minh (paginated). Filter: LoaiThongBao, TrangThai."
          },
          "response": []
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "stats"]
            }
          },
          "response": []
        },
        {
          "name": "Get Notification By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/{{notificationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "{{notificationId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Mark As Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "{{notificationId}}", "read"]
            }
          },
          "response": []
        },
        {
          "name": "Mark All As Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "read-all"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/thong-bao/{{notificationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "thong-bao", "{{notificationId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Smart Search",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"hoat dong the thao\",\n  \"limit\": 10\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "search"]
            },
            "description": "Tim kiem hoat dong thong minh bang AI (Gemini)."
          },
          "response": []
        },
        {
          "name": "Recommendations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limit\": 5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/recommend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "recommend"]
            },
            "description": "Goi y hoat dong phu hop dua tren lich su va so thich."
          },
          "response": []
        },
        {
          "name": "Ask Q&A",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Co hoat dong nao sap dien ra khong?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/ai/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ai", "ask"]
            },
            "description": "Hoi dap ve hoat dong, CLB bang AI. Tra loi tieng Viet."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Overview Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats/overview",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "stats", "overview"]
            },
            "description": "Thong ke tong quan: users, activities, clubs, registrations. Yeu cau ADMIN."
          },
          "response": []
        },
        {
          "name": "Activity Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/stats/activities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "stats", "activities"]
            },
            "description": "Thong ke hoat dong theo trang thai va danh muc. Yeu cau ADMIN."
          },
          "response": []
        }
      ]
    }
  ]
}
